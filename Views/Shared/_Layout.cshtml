<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Tata Steel UISL</title>

    <!-- Bootstrap 4 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap"
          rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/estimate.css" />
</head>
<body>

<!-- ══ TOP NAVBAR ══════════════════════════════════════════════ -->
<nav class="navbar navbar-expand-lg navbar-dark est-navbar">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <div class="brand-icon mr-2"><i class="fas fa-industry"></i></div>
            <div>
                <div class="brand-company">Tata Steel UISL</div>
                <div class="brand-module">Cost Estimation System</div>
            </div>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse"
                data-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")">
                    <a class="nav-link" href="/Estimate/Index">
                        <i class="fas fa-table mr-1"></i> Estimate
                    </a>
                </li>
                <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()=="History"?"active":"")">
                    <a class="nav-link" href="/Estimate/History">
                        <i class="fas fa-history mr-1"></i> History
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Estimate/CostBook" target="_blank">
                        <i class="fas fa-book-open mr-1"></i> Cost Book
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- ══ PAGE CONTENT ════════════════════════════════════════════ -->
<div class="page-wrapper">
    @RenderBody()
</div>

<!-- ══ FOOTER ══════════════════════════════════════════════════ -->
<footer class="est-footer">
    <div class="container-fluid px-4">
        <span>© @DateTime.Now.Year Tata Steel UISL &nbsp;·&nbsp;
              Estimate Pending – Cost Management System &nbsp;·&nbsp;
              Built with ASP.NET Core MVC</span>
    </div>
</footer>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
